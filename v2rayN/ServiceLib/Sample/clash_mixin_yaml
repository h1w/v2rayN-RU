#
# The config file content is not modified; mixing happens only in memory.
#
# Mind the indentation below; open this file with an editor that supports YAML.
#
# Using a Clash config keyword overrides the original config.
#
# removed-rules    iterate over each line of the rules array; matching lines are removed (put this rule first)
#
# append-rules    merge the array after the original rules array
# prepend-rules   merge the array before the original rules array
# append-proxies      merge the array after the original proxies array
# prepend-proxies     merge the array before the original proxies array
# append-proxy-groups     merge the array after the original proxy-groups array
# prepend-proxy-groups    merge the array before the original proxy-groups array
# append-rule-providers     merge the array after the original rule-providers array
# prepend-rule-providers    merge the array before the original rule-providers array
#

dns:
  enable: true
  enhanced-mode: fake-ip
  nameserver:
    - 114.114.114.114
    - 223.5.5.5
    - 8.8.8.8
  fallback: []
  fake-ip-filter:
    - +.stun.*.*
    - +.stun.*.*.*
    - +.stun.*.*.*.*
    - +.stun.*.*.*.*.*
    - "*.n.n.srv.nintendo.net"
    - +.stun.playstation.net
    - xbox.*.*.microsoft.com
    - "*.*.xboxlive.com"
    - "*.msftncsi.com"
    - "*.msftconnecttest.com"
    - WORKGROUP